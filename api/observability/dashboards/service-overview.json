{
  "id": null,
  "uid": "ailin-service-overview",
  "title": "Ailin API - Service Overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["ailin", "api", "production"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Latency (p50/p95/p99)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(ailin_dev_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ailin_dev_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ailin_dev_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (5m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(ailin_dev_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(ailin_dev_http_requests_total[5m]))",
          "legendFormat": "error-rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "LLM Token Usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(ailin_dev_llm_tokens_used_total{type=\"prompt\"}[5m])) by (provider)",
          "legendFormat": "prompt - {{provider}}"
        },
        {
          "expr": "sum(rate(ailin_dev_llm_tokens_used_total{type=\"completion\"}[5m])) by (provider)",
          "legendFormat": "completion - {{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cache Hit Ratio",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(ailin_dev_cache_hits_total[5m])) / (sum(rate(ailin_dev_cache_hits_total[5m])) + sum(rate(ailin_dev_cache_misses_total[5m])))",
          "legendFormat": "Global Hit Rate"
        },
        {
          "expr": "sum(rate(ailin_dev_cache_hits_total{cache_type=\"memory\"}[5m])) / sum(rate(ailin_dev_cache_hits_total[5m]))",
          "legendFormat": "Memory Hit Share"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" }
}

