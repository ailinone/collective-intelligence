{
  "name": "@ailin/dev-api",
  "version": "0.0.1",
  "description": "Ailin Dev API - Enterprise Multi-Model Orchestration Gateway",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "postinstall": "pnpm exec prisma generate",
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "tsx src/index.ts",
    "start:prod": "NODE_ENV=production tsx src/index.ts",
    "worker:start": "node dist/workers/queue-runner.js",
    "worker:dev": "tsx src/workers/queue-runner.ts",
    "test": "vitest run",
    "test:functional": "vitest run",
    "test:with-gcp": "cross-env TEST_USE_REAL_API_KEYS=true vitest run",
    "test:security": "vitest run src/tests/security/auth-security-matrix.test.ts",
    "test:coverage": "vitest --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:smoke": "vitest --run tests/smoke",
    "test:real": "vitest run",
    "test:all-operations": "vitest run tests/integration/all-140-operations.test.ts --testTimeout=300000 --hookTimeout=120000",
    "test:save-output": "node scripts/run-tests-save-output.js",
    "ensure-local-db": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ensure-local-postgres.ps1",
    "test:endpoints": "tsx scripts/test-endpoints-directly.ts",
    "operability:smoke": "tsx scripts/operability-smoke.ts",
    "test:evals": "pnpm run test:evals:mock",
    "test:evals:mock": "cross-env EVAL_MODE=mock vitest run --config vitest.evals.config.ts",
    "test:evals:live": "cross-env EVAL_MODE=live vitest run --config vitest.evals.config.ts",
    "test:evals:live:smoke": "cross-env EVAL_MODE=live vitest run --config vitest.evals.config.ts tests/evals/live-smoke.eval.ts",
    "test:evals:promptfoo": "promptfoo eval -c tests/evals/promptfoo/promptfooconfig.yaml",
    "test:evals:redteam": "vitest run tests/evals/redteam-ci.test.ts",
    "test:evals:all": "pnpm test:evals:mock && pnpm test:evals:promptfoo && pnpm test:evals:redteam",
    "eval:preflight": "tsx scripts/evals/run-enterprise-preflight.ts",
    "eval:benchmark:baseline": "tsx scripts/evals/run-enterprise-benchmark.ts --stage baseline",
    "eval:benchmark:remediated": "tsx scripts/evals/run-enterprise-benchmark.ts --stage remediated",
    "eval:benchmark:diff": "tsx scripts/evals/compare-enterprise-benchmarks.ts",
    "eval:inventory": "tsx scripts/evals/run-model-inventory-audit.ts",
    "eval:market": "tsx scripts/evals/generate-market-comparison-evidence.ts",
    "eval:report": "tsx scripts/evals/build-enterprise-report.ts",
    "eval:deploy:package": "tsx scripts/evals/package-deploy-evidence.ts",
    "eval:enterprise:all": "pnpm eval:preflight && pnpm eval:benchmark:baseline && pnpm eval:benchmark:remediated && pnpm eval:benchmark:diff && pnpm eval:market && pnpm eval:report",
    "eval:routing-superiority": "node tests/evals/routing-superiority-benchmark.mjs",
    "eval:retrieval": "node tests/evals/retrieval-benchmark.mjs",
    "eval:tool-use": "node tests/evals/tool-use-benchmark.mjs",
    "eval:evidence-pack": "tsx scripts/generate-evidence-pack.ts",
    "eval:tier1-suite": "node tests/evals/run-evals.mjs --ci --fail-threshold=0.80 && node tests/evals/routing-superiority-benchmark.mjs --ci --fail-threshold=0.03 && node tests/evals/retrieval-benchmark.mjs --ci --fail-threshold=0.60 && node tests/evals/tool-use-benchmark.mjs --ci --fail-threshold=0.70",
    "validate-gcp-secrets": "tsx scripts/validate-gcp-secrets.ts",
    "lint": "tsx scripts/lint-no-regression.ts",
    "lint:full": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "lint:baseline:update": "tsx scripts/lint-no-regression.ts --update-baseline",
    "lint:architecture": "tsx scripts/lint-architecture-boundaries.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" && eslint --fix \"src/**/*.ts\"",
    "format:analyze": "prettier --check \"src/**/*.ts\" && eslint \"src/**/*.ts\" --format=compact",
    "pretypecheck": "pnpm exec prisma generate",
    "calibrate:judge": "tsx scripts/run-judge-calibration.ts",
    "c3:v4": "node scripts/run-c3-v4.mjs",
    "providers:revalidate": "node scripts/revalidate-providers.mjs",
    "check:orphans": "node scripts/check-orphans.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:npx": "npx --no-install tsc --noEmit",
    "typecheck:safety": "tsx scripts/validate-type-safety.ts",
    "typecheck:safety:strict": "tsx scripts/validate-type-safety.ts --strict",
    "typecheck:metrics": "tsx scripts/type-safety-metrics.ts",
    "typecheck:metrics:json": "tsx scripts/type-safety-metrics.ts --json",
    "test:security:auth-claims": "vitest run --config vitest.ci.config.ts src/tests/security/auth-claims-regression.test.ts",
    "generate:openapi": "tsx scripts/generate-openapi.ts",
    "generate:openapi:auto": "tsx scripts/extract-openapi-from-server.ts",
    "generate:openapi:enterprise": "pnpm run generate:openapi:auto && pnpm exec tsx scripts/sync-openapi-from-diff.ts && pnpm run validate:openapi",
    "validate:collective-contract": "tsx scripts/validate-collective-contract.ts",
    "validate:openapi": "tsx scripts/validate-openapi-specs.ts && tsx scripts/validate-collective-contract.ts",
    "db:migrate": "tsx src/database/migrate.ts",
    "db:seed": "tsx src/database/seed.ts",
    "db:reset": "tsx src/database/reset.ts",
    "observability:validate": "tsx scripts/observability/validate.ts",
    "observability:check-runtime": "tsx scripts/observability/check-runtime-metrics.ts",
    "security:sync-roles": "tsx scripts/security/sync-roles.ts",
    "load-test:discovery": "tsx scripts/load-test-discovery.ts",
    "cloudrun:deploy": "bash ./scripts/deploy-cloud-run.sh"
  },
  "keywords": [
    "ailin",
    "llm",
    "orchestration",
    "multi-model",
    "enterprise",
    "ai",
    "chatgpt",
    "claude",
    "gemini"
  ],
  "author": "Ailin Team",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.18.0",
    "@aws-sdk/client-bedrock": "^3.940.0",
    "@aws-sdk/client-bedrock-runtime": "^3.940.0",
    "@aws-sdk/client-sagemaker": "^3.1035.0",
    "@aws-sdk/client-sagemaker-runtime": "^3.1035.0",
    "@aws-sdk/client-secrets-manager": "^3.614.0",
    "@aws-sdk/client-ses": "^3.614.0",
    "@azure/identity": "^4.1.0",
    "@azure/keyvault-secrets": "^4.7.0",
    "@fastify/compress": "^8.2.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.6.0",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/websocket": "^11.2.0",
    "@google-cloud/secret-manager": "^6.1.1",
    "@google-cloud/storage": "^7.18.0",
    "@google/generative-ai": "^0.2.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@openai/agents": "^0.0.3",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.42.0",
    "@opentelemetry/exporter-jaeger": "^1.23.0",
    "@opentelemetry/exporter-prometheus": "^0.49.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.49.1",
    "@opentelemetry/resources": "^1.12.0",
    "@opentelemetry/sdk-node": "^0.49.1",
    "@opentelemetry/semantic-conventions": "^1.12.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@prisma/client-runtime-utils": "^7.2.0",
    "@sendgrid/mail": "^8.1.0",
    "@sentry/node": "^10.22.0",
    "@sentry/profiling-node": "^10.22.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.4.0",
    "docx": "^9.7.1",
    "dotenv": "^16.4.1",
    "eventsource-parser": "^1.1.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "fastify": "^5.6.1",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.3.2",
    "jszip": "^3.10.1",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.2.2",
    "module-alias": "^2.2.3",
    "nanoid": "^5.0.5",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.13",
    "openai": "^4.28.0",
    "pdfkit": "^0.19.1",
    "pg": "^8.16.3",
    "pino": "^8.18.0",
    "pino-pretty": "^10.3.1",
    "pptxgenjs": "^4.0.1",
    "prisma": "^7.2.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "stripe": "^14.24.0",
    "tsyringe": "^4.10.0",
    "undici": "^7.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "optionalDependencies": {
    "@google-cloud/kms": "^4.5.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.10.3",
    "@testcontainers/redis": "^10.10.3",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.17",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.13",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.16.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.2.2",
    "autoevals": "^0.0.132",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "fast-check": "^3.23.2",
    "pdf-parse": "^2.4.5",
    "prettier": "^3.2.5",
    "promptfoo": "^0.120.24",
    "testcontainers": "^10.10.3",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2",
    "vitest-evals": "^0.5.0",
    "ws": "^8.16.0",
    "yaml": "^2.5.0"
  },
  "pnpm": {
    "overrides": {
      "fast-jwt": "6.2.4",
      "protobufjs@7": "7.6.5",
      "fast-xml-parser": "5.3.6",
      "axios": "1.13.5",
      "qs": "6.14.2",
      "fastify": "5.7.2",
      "tar": "7.5.8",
      "jws@3": "3.2.3",
      "jws@4": "4.0.1",
      "minimatch@3": "3.1.4",
      "minimatch@5": "5.1.8",
      "minimatch@9": "9.0.7",
      "minimatch@10": "10.2.3",
      "glob@10": "10.5.0",
      "glob@11": "11.1.0"
    }
  }
}
