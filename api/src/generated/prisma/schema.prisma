// Ailin Dev API - Database Schema
// PostgreSQL with Prisma ORM
// Updated for Prisma 7.x compatibility

generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  // Note: postgresqlExtensions is still a preview feature in Prisma 7
  previewFeatures = ["postgresqlExtensions"]
  // Explicitly generate CommonJS for compatibility with our CommonJS build
  // This ensures the generated client uses require() instead of import
  engineType      = "library"
}

datasource db {
  provider   = "postgresql"
  extensions = [pgcrypto, pg_trgm]
}

// ============================================
// Organizations & Users
// ============================================

model Organization {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  slug         String?  @unique // URL-friendly identifier for tenant discovery
  tier         String   @default("free") // free, pro, team, enterprise
  status       String   @default("active") // active, suspended, deleted
  statusReason String?  @map("status_reason")
  settings     Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users               User[]
  invites             OrganizationInvite[]
  deviceFlows         AuthDeviceFlow[]
  apiKeys             ApiKey[]
  usageQuotas         UsageQuota[]
  requestLogs         RequestLog[]
  modelConfigs        ModelConfig[]
  codebaseProjects    CodebaseProject[]
  billingProfile      BillingProfile?
  invoices            Invoice[]
  subscriptions       BillingSubscription[]
  usageEvents         UsageEvent[]
  userRoles           UserRole[]
  securityAuditLogs   SecurityAuditLog[]
  taskPreferences     TaskPreference[]
  performanceMetrics  ModelPerformanceMetric[]
  selectionStrategies ModelSelectionStrategy[]
  fineTuningJobs      FineTuningJob[]
  collectiveRuns      CollectiveRun[]
  projects            Project[]
  moderationPolicies  ModerationPolicy[]

  @@map("organizations")
}

// Project — resource-layer sub-entity within an Organization.
//
// Scope: container for resources consumed by a single application or use-case
// (API keys, deploys, telemetry). Org owns members + billing; Project owns
// resources. Slug is unique per-org (two orgs can both have "customer-portal").
//
// Status enum is intentionally minimal (active | archived). Archived = soft
// delete with archivedAt timestamp; hard delete is admin-only via a separate
// flow. The `settings` JSON column is an extensibility escape hatch — region,
// default model, webhook URLs etc. can land there without schema migrations.
model Project {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  name           String
  slug           String
  description    String?   @db.Text
  status         String    @default("active") // active | archived
  settings       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  archivedAt     DateTime? @map("archived_at")
  createdBy      String    @map("created_by") @db.Uuid

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@index([organizationId, createdAt(sort: Desc)])
  @@map("projects")
}

// ModerationPolicy — per-tenant custom content-moderation policy (F3/F1 §P6).
//
// A policy layers org-specific category thresholds (and optional custom
// categories) on top of the base OpenAI-style /v1/moderations result. When a
// request passes `policy_id`, the policy is loaded (org-scoped) and applied:
// any category whose base score meets/exceeds the org threshold is re-flagged,
// and the configured `action` (flag | block) drives the response semantics.
//
// Design notes:
//   - `thresholds` JSON maps a category key (e.g. "hate", "violence", or a
//     custom category name) → number in [0,1]. A score ≥ threshold trips it.
//   - `customCategories` JSON (optional) declares org-defined categories that
//     don't exist in the base provider taxonomy; their score is keyword/regex
//     matched at apply time (see moderation-policy-service applyPolicy).
//   - `action` is minimal enum: 'flag' (annotate only) | 'block' (caller MUST
//     reject the content). DB CHECK enforces the enum — fail loud on drift.
//   - `enabled=false` short-circuits application (policy is inert but kept for
//     audit / re-enable) — apply treats it as a no-op pass-through.
//   - Scoped per-org; uniqueness of (organizationId, name) prevents duplicate
//     policy names within a tenant without colliding across tenants.
model ModerationPolicy {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  name             String
  thresholds       Json     @default("{}")
  customCategories Json?    @map("custom_categories")
  action           String   @default("flag") // flag | block
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, enabled])
  @@map("moderation_policies")
}

model User {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @unique @db.Citext
  name           String
  passwordHash   String    @map("password_hash") // bcrypt hashed password
  organizationId String    @map("organization_id") @db.Uuid
  role           String    @default("viewer")
  status         String    @default("active") // active, suspended, inactive
  statusReason   String?   @map("status_reason")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization      Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdInvites    OrganizationInvite[] @relation("InviteCreatedBy")
  acceptedInvites   OrganizationInvite[] @relation("InviteAcceptedBy")
  deviceFlows       AuthDeviceFlow[]
  apiKeys           ApiKey[]
  userRoles         UserRole[]
  securityAuditLogs SecurityAuditLog[]

  @@index([organizationId])
  @@index([email])
  @@map("users")
}

model OrganizationInvite {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  token          String    @unique
  email          String?
  role           String    @default("viewer")
  status         String    @default("pending") // pending, accepted, expired, revoked
  expiresAt      DateTime? @map("expires_at")
  acceptedAt     DateTime? @map("accepted_at")
  acceptedById   String?   @map("accepted_by_id") @db.Uuid
  createdById    String    @map("created_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("InviteCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  acceptedBy   User?        @relation("InviteAcceptedBy", fields: [acceptedById], references: [id])

  @@index([token])
  @@index([organizationId])
  @@index([email])
  @@index([status])
  @@map("organization_invites")
}

model AuthDeviceFlow {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceCode     String    @unique
  userCode       String    @unique
  organizationId String    @map("organization_id") @db.Uuid
  idpProvider    String
  status         String    @default("pending") // pending, completed, denied, expired
  userId         String?   @map("user_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at")
  interval       Int       @default(5) // Poll interval in seconds
  lastPolledAt   DateTime? @map("last_polled_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([deviceCode])
  @@index([userCode])
  @@index([organizationId])
  @@index([status])
  @@map("auth_device_flows")
}

model ApiKey {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  keyHash        String  @map("key_hash") // bcrypt hashed API key
  keyPrefix      String  @map("key_prefix") // First 15 chars for lookup (e.g., "ak_live_abc123")
  quickHash      String? @map("quick_hash") // SHA-256 for fast lookup (v5.0)
  userId         String  @map("user_id") @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  status         String  @default("active") // active, rotating, revoked, expired (v5.0: added 'rotating')
  statusReason   String? @map("status_reason")

  // Usage tracking
  lastUsedAt    DateTime @default(now()) @map("last_used_at")
  requestCount  Int      @default(0) @map("request_count") // v5.0
  lastRequestIp String?  @map("last_request_ip") // v5.0

  // Expiration
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  // Rotation tracking (v5.0)
  rotatedAt     DateTime? @map("rotated_at")
  revokedAt     DateTime? @map("revoked_at")
  rotationCount Int       @default(0) @map("rotation_count")
  previousKeyId String?   @map("previous_key_id") @db.Uuid
  nextKeyId     String?   @map("next_key_id") @db.Uuid

  // Security (v5.0)
  ipWhitelist String[] @default([]) @map("ip_whitelist")
  permissions Json? // Fine-grained permissions

  // Auto-rotation config (v5.0)
  autoRotate           Boolean @default(false) @map("auto_rotate")
  rotationIntervalDays Int?    @map("rotation_interval_days")
  gracePeriodDays      Int     @default(7) @map("grace_period_days")

  // Metadata
  metadata Json?

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rotationLogs ApiKeyRotationLog[]

  @@index([keyPrefix])
  @@index([quickHash])
  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@index([status, expiresAt])
  @@map("api_keys")
}

// v5.0: API Key Rotation Audit Trail
model ApiKeyRotationLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  apiKeyId    String   @map("api_key_id") @db.Uuid
  action      String // 'created' | 'rotated' | 'revoked' | 'expired'
  reason      String? // Manual, scheduled, security incident
  oldKeyId    String?  @map("old_key_id") @db.Uuid
  newKeyId    String?  @map("new_key_id") @db.Uuid
  performedBy String?  @map("performed_by") @db.Uuid // User ID if manual
  performedAt DateTime @default(now()) @map("performed_at")
  metadata    Json?

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([performedAt])
  @@map("api_key_rotation_logs")
}

// ============================================
// Models & Providers
// ============================================

model Provider {
  id              String    @id @db.VarChar(64)
  name            String    @unique // openai, anthropic, google, deepseek, xai, mistral, cohere
  displayName     String    @map("display_name")
  status          String    @default("active") // active, maintenance, disabled
  health          Json      @default("{}")
  metadata        Json      @default("{}")
  modelCount      Int       @default(0) @map("model_count")
  lastDiscoveryAt DateTime? @map("last_discovery_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  models Model[]

  @@map("providers")
}

model Model {
  // Deterministic surrogate PK: MD5(provider_id + ':' + id)[0:25]
  // Allows the same model ID (e.g. "gpt-4o") to exist under multiple providers.
  uid             String    @id @db.VarChar(32)
  id              String    @db.VarChar(128)
  providerId      String    @map("provider_id") @db.VarChar(64)
  name            String // gpt-4o, claude-3-opus-20240229, etc.
  displayName     String    @map("display_name")
  contextWindow   Int       @map("context_window")
  maxOutputTokens Int       @map("max_output_tokens")
  inputCostPer1k  Decimal   @map("input_cost_per_1k") @db.Decimal(10, 6)
  outputCostPer1k Decimal   @map("output_cost_per_1k") @db.Decimal(10, 6)
  capabilities    Json      @default("[]") // DEPRECATED — derived projection of capabilityUris. Read capabilityUris instead.
  performance     Json      @default("{}") // { latency, throughput, quality }
  status          String    @default("active") // active, deprecated, disabled
  metadata        Json      @default("{}")
  usageCount      Int       @default(0) @map("usage_count")
  lastSyncedAt    DateTime? @map("last_synced_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // ─── ADR-022 / HCRA (2026-04-20) ───────────────────────────────────────
  // Primary capability index. URIs reference capability_ontology(uri).
  // The bandit recall layer (L5/L10) filters by intersecting this array
  // with the required-capability set from the request context. A GIN index
  // on the physical column backs the filter; GIN over confidence JSONB
  // backs confidence-weighted ranking.
  capabilityUris       String[]  @default([]) @map("capability_uris")
  capabilityConfidence Json      @default("{}") @map("capability_confidence") // {uri: 0..1}
  capabilitySources    Json      @default("{}") @map("capability_sources") // {uri: [source,...]}
  capabilityUpdatedAt  DateTime? @map("capability_updated_at")

  // ─── L2 Model Equivalence (2026-04-14) + ADR-022 embedding versioning ──
  // 384-dim embedding from the on-the-fly n-gram pipeline (phase 1) or a
  // produced-by-service embedder (phase 2). Marked Unsupported because
  // Prisma has no first-class pgvector type — reads/writes use $queryRaw.
  // The HNSW cosine-ops index is partial (status = 'active') and backs
  // similarity queries for cross-provider equivalence lookup.
  embedding          Unsupported("vector(384)")? // pgvector — HNSW partial index on (status='active')
  embeddingModel     String?                     @map("embedding_model") @db.VarChar(64)
  embeddingUpdatedAt DateTime?                   @map("embedding_updated_at")

  // ─── ADR-023 / Inventory Lifecycle Policy (2026-04-24) ────────────────
  // Freshness-of-observation bucket derived from updated_at, orthogonal to
  // `status` (catalog availability). Populated by scripts/hcra-lifecycle-classify.ts
  // using the canonical CASE expression in src/capability/inventory-lifecycle-policy.ts.
  // SLO-grade coverage queries MUST filter on lifecycle_status='active'; raw
  // status='active' is retained for historical comparisons only. The partial
  // index on lifecycle_status (WHERE status='active') backs hot-path lookups.
  lifecycleStatus      String?   @map("lifecycle_status") @db.VarChar(16)
  lifecycleReason      String?   @map("lifecycle_reason")
  lifecycleEvaluatedAt DateTime? @map("lifecycle_evaluated_at")

  provider     Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  modelConfigs ModelConfig[]
  health       ModelHealth?

  // Multi-provider: same model ID across different providers
  @@unique([id, providerId])
  @@unique([providerId, name])
  @@index([providerId, status]) // Common: filter by provider and status
  @@index([status, usageCount]) // Common: filter active models by popularity
  @@index([providerId, status, usageCount]) // Optimize complex filters
  @@index([lastSyncedAt]) // For discovery sync queries
  @@index([updatedAt]) // For change tracking and cache invalidation
  @@map("models")
}

model ModelConfig {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  modelId        String   @map("model_id") @db.VarChar(128) // Kept for auditing/queries
  modelUid       String?  @map("model_uid") @db.VarChar(32) // FK to models.uid
  alias          String? // Custom name for this model
  priority       Int      @default(100) // Higher = preferred
  enabled        Boolean  @default(true)
  config         Json     @default("{}") // Custom parameters
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  model        Model?       @relation(fields: [modelUid], references: [uid], onDelete: Cascade)

  @@unique([organizationId, modelId])
  @@index([organizationId])
  @@index([modelId])
  @@map("model_configs")
}

model ModelHealth {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  modelId             String   @map("model_id") @db.VarChar(128) // Kept for auditing/queries
  modelUid            String?  @unique @map("model_uid") @db.VarChar(32) // FK to models.uid
  status              String   @default("healthy") // healthy, degraded, down
  latencyMs           Int?     @map("latency_ms")
  errorRate           Float?   @map("error_rate")
  availability        Float?   @map("availability")
  loadFactor          Float?   @map("load_factor")
  lastCheckedAt       DateTime @default(now()) @map("last_checked_at")
  consecutiveFailures Int      @default(0) @map("consecutive_failures")
  metadata            Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  model Model? @relation(fields: [modelUid], references: [uid], onDelete: Cascade)

  @@unique([modelId])
  @@index([status])
  @@index([lastCheckedAt])
  @@map("model_health")
}

// ============================================
// Request Logs & Analytics
// ============================================

model RequestLog {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String @map("organization_id") @db.Uuid
  requestId      String @unique @map("request_id")
  endpoint       String
  method         String

  // Orchestration details
  strategyId   String? @map("strategy_id")
  strategyName String? @map("strategy_name")
  modelsUsed   Json    @default("[]") @map("models_used") // Array of model IDs
  modelCount   Int     @default(1) @map("model_count")

  // Primary model (for compatibility)
  modelId String? @map("model_id") @db.VarChar(128)

  // Performance
  durationMs  Int  @map("duration_ms")
  queueTimeMs Int? @map("queue_time_ms")

  // Tokens
  inputTokens  Int @default(0) @map("input_tokens")
  outputTokens Int @default(0) @map("output_tokens")
  totalTokens  Int @default(0) @map("total_tokens")

  // Cost
  costUsd Decimal @map("cost_usd") @db.Decimal(10, 6)

  // Quality
  qualityScore Decimal? @map("quality_score") @db.Decimal(3, 2)

  // Request/Response
  request  Json @default("{}")
  response Json @default("{}")

  // Error handling
  status       String  @default("success") // success, error, timeout
  errorCode    String? @map("error_code")
  errorMessage String? @map("error_message")

  // Metadata
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  // Sharding (for massive scale: 10,000+ developers)
  shardId Int? @map("shard_id") // Generated from organization_id hash

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Note: model FK was removed in 20260410_multi_provider_models migration.
  // modelId is retained as a plain text reference for auditing — no FK constraint.

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([requestId])
  @@index([strategyId])
  @@index([createdAt(sort: Desc)])
  // getRuntimeSignals (models-routes.ts): WHERE endpoint = ... AND created_at > now()-48h,
  // refreshed every 60s. See migration 20260711000000 for the partition-aware
  // production application procedure (the live table is partitioned by month).
  @@index([endpoint, createdAt(sort: Desc)])
  @@index([status])
  @@index([shardId]) // Critical for shard-aware queries
  @@index([shardId, organizationId, createdAt(sort: Desc)]) // Composite for best performance
  @@map("request_logs")
}

// ============================================
// Ailin¹ Collective Coordination Layer (F1.5)
// ============================================
// Persistence for sensitivity-consensus (and future collective)
// strategy runs. A `CollectiveRun` represents one full multi-round
// coordination attempt; a `CollectiveSignal` is one agent's
// decision+sensitivity emission within a specific round.
// PII has already been redacted at the validator boundary
// (see signal-validator.ts) before any field reaches this table.

model CollectiveRun {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  requestId      String? @map("request_id") // links back to RequestLog when run is part of a chat completion
  strategy       String  @db.VarChar(64)
  config         Json    @default("{}") // CoordinationConfig snapshot at run start

  // Outcome
  rounds           Int
  stopReason       String  @map("stop_reason") @db.VarChar(64)
  convergenceScore Decimal @default(0) @map("convergence_score") @db.Decimal(4, 3)
  decisionFlipRate Decimal @default(0) @map("decision_flip_rate") @db.Decimal(4, 3)
  dissent          Decimal @default(0) @db.Decimal(4, 3)

  // Resource accounting
  totalCostUsd   Decimal @default(0) @map("total_cost_usd") @db.Decimal(10, 6)
  totalLatencyMs Int     @default(0) @map("total_latency_ms")
  totalTokens    Int     @default(0) @map("total_tokens")

  // Final decision
  finalDecisionType String?  @map("final_decision_type") @db.VarChar(64)
  finalConfidence   Decimal? @map("final_confidence") @db.Decimal(3, 2)

  // Free-form audit / dominantSensitivities / criticalVariables / etc.
  metadata Json @default("{}")

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  signals      CollectiveSignal[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([requestId])
  @@index([strategy])
  @@map("collective_runs")
}

model CollectiveSignal {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId String @map("run_id") @db.Uuid
  round Int

  // Agent identification
  agentId    String  @map("agent_id") @db.VarChar(128)
  modelId    String  @map("model_id") @db.VarChar(128)
  providerId String  @map("provider_id") @db.VarChar(64)
  role       String? @db.VarChar(32)

  // Decision (PII-redacted upstream by signal-validator)
  decisionType       String  @map("decision_type") @db.VarChar(64)
  decisionValue      Json    @map("decision_value")
  decisionConfidence Decimal @map("decision_confidence") @db.Decimal(3, 2)
  decisionRationale  String? @map("decision_rationale")

  // Sensitivities (Sensitivity[] — array of structured signals)
  sensitivities Json @default("[]")

  // Per-call metrics
  latencyMs    Int?     @map("latency_ms")
  inputTokens  Int?     @map("input_tokens")
  outputTokens Int?     @map("output_tokens")
  costUsd      Decimal? @map("cost_usd") @db.Decimal(10, 6)

  createdAt DateTime @default(now()) @map("created_at")

  run CollectiveRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, round])
  @@index([modelId])
  @@map("collective_signals")
}

// ============================================
// Auto-Learning System
// ============================================

model LearningData {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bucket     String @db.VarChar(50) // '2025-11-04-10'
  taskType   String @map("task_type") @db.VarChar(50)
  complexity String @db.VarChar(20)

  // Aggregated metrics
  count        Int     @default(0)
  successCount Int     @default(0) @map("success_count")
  avgQuality   Decimal @default(0) @map("avg_quality") @db.Decimal(3, 2)
  avgCost      Decimal @default(0) @map("avg_cost") @db.Decimal(10, 6)
  avgLatency   Int     @default(0) @map("avg_latency")

  // Strategy distribution (compact JSON)
  strategyDistribution Json @default("{}") @map("strategy_distribution") // {"parallel": 45, "sequential": 30}

  // Top patterns (only top 5)
  topPatterns Json @default("[]") @map("top_patterns")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([bucket, taskType, complexity])
  @@index([bucket])
  @@index([taskType, complexity])
  @@map("learning_data")
}

// ============================================
// Sharding Configuration
// ============================================

model ShardConfig {
  shardId      Int      @id @map("shard_id")
  shardName    String   @map("shard_name") @db.VarChar(50)
  status       String   @default("active") // active, readonly, maintenance, disabled
  orgCount     Int      @default(0) @map("org_count")
  requestCount BigInt   @default(0) @map("request_count")
  totalSizeMb  Decimal  @default(0) @map("total_size_mb") @db.Decimal(10, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

