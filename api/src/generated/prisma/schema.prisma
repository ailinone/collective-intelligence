/// I1 fix (ADR/RFC-006): Invoice with saga status tracking.
/// Status flow: pending_stripe_sync → stripe_synced → finalized → paid
///                                  ↘ stripe_sync_failed (recoverable by reconciliation job)
model Invoice {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        String    @map("organization_id") @db.Uuid
  periodStart           DateTime  @map("period_start")
  periodEnd             DateTime  @map("period_end")
  subtotal              Decimal   @db.Decimal(14, 4)
  tax                   Decimal   @db.Decimal(14, 4)
  total                 Decimal   @db.Decimal(14, 4)
  currency              String
  status                String    @default("pending_stripe_sync")
  dueDate               DateTime  @map("due_date")
  hostedInvoiceUrl      String?   @map("hosted_invoice_url")
  stripeInvoiceId       String?   @map("stripe_invoice_id")
  stripePaymentIntentId String?   @map("stripe_payment_intent_id")
  stripeCustomerId      String?   @map("stripe_customer_id")
  lastSyncedAt          DateTime? @map("last_synced_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  paidAt                DateTime? @map("paid_at")
  lastError             String?   @map("last_error") @db.Text
  metadata              Json?     @default("{}")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items        InvoiceItem[]

  @@index([organizationId, periodStart])
  @@index([status])
  @@index([status, updatedAt])
  @@map("invoices")
}

