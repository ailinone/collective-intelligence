# ============================================
# Ailin Dev API - Environment Configuration
# ============================================
# This file contains ONLY non-sensitive configuration.
# All secrets are stored in GCP Secret Manager.
#
# Project: YOUR_GCP_PROJECT_ID
# Secrets prefix: <your-prefix>-*
# ============================================

# ============================================
# Secrets Manager Configuration
# ============================================
SECRETS_PROVIDER_PRIMARY=gcp
SECRETS_PROVIDER_FALLBACK=env
SECRETS_CACHE_TTL_SECONDS=300
SECRETS_AUTO_REFRESH=true
SECRETS_ENCRYPT_CACHE=true
SECRETS_AUDIT_ENABLED=true
SECRETS_AUDIT_PERSIST=true
SECRETS_ROTATION_CRON=0 3 * * *

# GCP Secret Manager
GCP_SECRETS_PROJECT_ID=YOUR_GCP_PROJECT_ID
GCP_SECRETS_PREFIX=your-prefix

# For local development only (not needed in Cloud Run):
# GCP_SECRETS_CREDENTIALS_FILE=./service-account-key.json

# ============================================
# Branding Configuration
# ============================================
AILIN_HIDE_MODELS=false
AILIN_BRAND_NAME=Ailin¹
AILIN_MINIMAL_METADATA=false
AILIN_LOG_DETAILED_METADATA=true

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Application Metadata
APP_VERSION=2.1.0
CLI_MIN_VERSION=0.0.1
CLI_LATEST_VERSION=0.1.9
GIT_COMMIT_SHA=
BUILD_TIMESTAMP=

# ============================================
# Database (PostgreSQL) - Non-sensitive Config
# ============================================
# Connection string comes from GCP Secret: <prefix>-database-url
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=50
DATABASE_CONNECTION_TIMEOUT=5000
DATABASE_IDLE_TIMEOUT=30000

# ============================================
# Redis (Cache & Queue) - Non-sensitive Config
# ============================================
# Connection strings come from GCP Secrets:
# - <prefix>-redis-url
# - <prefix>-redis-global-url
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_NODES=

# ============================================
# Queue (BullMQ)
# ============================================
QUEUE_ENABLED=true
QUEUE_NAME=chat-requests
QUEUE_WORKER_COUNT=20
QUEUE_WORKER_CONCURRENCY=100
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_INITIAL_DELAY_MS=1000
QUEUE_BACKOFF_STRATEGY=exponential
QUEUE_RESULT_TTL_SECONDS=86400
QUEUE_STATUS_TTL_SECONDS=600
QUEUE_MAX_QUEUE_TIME_SECONDS=120
QUEUE_POLL_INTERVAL_MS=2000
QUEUE_RUN_WORKERS_IN_API=true
QUEUE_WORKER_METRICS_PORT=9465

# ============================================
# JWT Authentication
# ============================================
# JWT secret comes from GCP Secret: <prefix>-jwt-secret
JWT_EXPIRES_IN=24h

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=3600000

# ============================================
# Provider Base URLs (Non-sensitive)
# ============================================
# API keys come from GCP Secrets (<prefix>-*-key)

# Provider: OpenAI
OPENAI_ORGANIZATION=your-org-id-here
OPENAI_PROJECT_ID=your-project-id-here
OPENAI_BASE_URL=https://api.openai.com/v1

# Provider: Anthropic
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_ORGANIZATION_ID=your-org-id-here

# Provider: Google (Gemini)
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# Provider: DeepSeek
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Provider: Mistral
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Provider: xAI (Grok)
XAI_BASE_URL=https://api.x.ai

# Provider: Cohere
COHERE_BASE_URL=https://api.cohere.ai

# Provider: Vertex AI (Google Cloud)
VERTEX_AI_PROJECT_ID=YOUR_GCP_PROJECT_ID
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_BASE_URL=
VERTEX_AI_USE_EXPRESS_MODE=false

# Provider: Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Provider: OpenRouter
OPENROUTER_APP_URL=https://ailin.dev
OPENROUTER_APP_NAME=Ailin¹

# Provider: ORQ.ai
ORQAI_BASE_URL=https://api.orq.ai/v2/router
ORQAI_MODELS_BASE_URL=https://api.orq.ai

# Provider: Eden AI
EDENAI_BASE_URL=https://api.edenai.run/v3/llm

# Provider: Helicone AI Gateway
HELICONEAI_BASE_URL=https://ai-gateway.helicone.ai/v1

# Provider: AWS Bedrock
AWS_BEDROCK_REGION=us-east-1

# ============================================
# Observability: OpenTelemetry
# ============================================
OTEL_ENABLED=true
OTEL_SERVICE_NAME=ci-api
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTEL_EXPORTER_PROMETHEUS_PORT=9464

# ============================================
# Monitoring: Prometheus
# ============================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_TOKEN=generate-long-token

# ============================================
# Cache Configuration
# ============================================
CACHE_ENABLED=true
CACHE_TTL_DEFAULT=3600
CACHE_TTL_MODELS=3600
CACHE_TTL_RESPONSES=86400
CACHE_TTL_EMBEDDINGS=604800
CACHE_MAX_SIZE_MB=256
CACHE_MAX_IN_MEMORY_ENTRIES=5000

# ============================================
# Security
# ============================================
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
HELMET_ENABLED=true
COMPRESSION_ENABLED=true
MAX_REQUEST_SIZE_MB=10
SECURITY_RBAC_DEFAULT_ROLE=viewer
SECURITY_RBAC_SUPER_ROLES=owner,admin
SECURITY_AUDIT_ENABLED=true
SECURITY_AUDIT_RETENTION_DAYS=365

# ============================================
# Payments / Stripe
# ============================================
# Stripe keys come from GCP Secrets:
# - <prefix>-stripe-secret-key
# - <prefix>-stripe-webhook-secret
STRIPE_ENABLED=true
STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key-here
STRIPE_API_VERSION=2024-06-20
STRIPE_API_BASE_URL=https://api.stripe.com
STRIPE_DEFAULT_CURRENCY=usd
STRIPE_AUTOMATIC_TAX=true

# ============================================
# Email (SMTP)
# ============================================
# SMTP password comes from GCP Secret: <prefix>-smtp-pass
AUTH_EMAIL_PROVIDER=smtp
AUTH_EMAIL_FROM_EMAIL=no-reply@ailin.dev
AUTH_EMAIL_FROM_NAME=Ailin¹ Developer Tool
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@example.com

# ============================================
# Feature Flags
# ============================================
FEATURE_STREAMING=true
FEATURE_FUNCTION_CALLING=true
FEATURE_VISION=true
FEATURE_EMBEDDINGS=true
FEATURE_CACHING=true
FEATURE_AUTO_LEARNING=true
FEATURE_COMPETITIVE_EXECUTION=true
FEATURE_ARBITRATION=true

# ============================================
# Auto-Learning
# ============================================
AUTO_LEARNING_ENABLED=true
AUTO_LEARNING_BUCKET_SIZE_HOURS=1
AUTO_LEARNING_RETENTION_DAYS=365

# ============================================
# Orchestration
# ============================================
ORCHESTRATION_MAX_MODELS=9
ORCHESTRATION_DEFAULT_STRATEGY=auto
ORCHESTRATION_ENABLE_PARALLEL=true
ORCHESTRATION_ENABLE_COMPETITIVE=true
ORCHESTRATION_ENABLE_ARBITRATION=true

# ============================================
# Ailin Virtual Model Aliases
# ============================================
# Optional comma-separated aliases that always resolve to autonomous orchestration.
# Example: AILIN_AUTO_MODEL_ALIASES=ailin-smart,ailin-pro
AILIN_AUTO_MODEL_ALIASES=

# Optional JSON array with custom alias profiles.
# Example:
# AILIN_VIRTUAL_MODEL_PROFILES=[{"id":"ailin-research","strategy":"consensus","qualityTarget":0.95,"maxCost":0.08,"endpoints":["chat","responses"]}]
AILIN_VIRTUAL_MODEL_PROFILES=

# ============================================
# Cost Optimization
# ============================================
COST_OPTIMIZATION_ENABLED=true
COST_OPTIMIZATION_TARGET_SAVINGS=0.63
COST_OPTIMIZATION_MAX_BUDGET_PER_REQUEST=1.00

# ============================================
# Development
# ============================================
MOCK_PROVIDERS=false
ENABLE_SWAGGER=true
ENABLE_PLAYGROUND=true
ENABLE_GRACEFUL_SHUTDOWN=true
SHUTDOWN_TIMEOUT_MS=30000

