# ============================================
# Ailin Dev API - Environment Configuration
# ============================================
# This file contains ONLY non-sensitive configuration.
# All secrets are stored in GCP Secret Manager.
#
# Project: YOUR_GCP_PROJECT_ID
# Secrets prefix: <your-prefix>-*
# ============================================

# ============================================
# Secrets Manager Configuration
# ============================================
SECRETS_PROVIDER_PRIMARY=gcp
SECRETS_PROVIDER_FALLBACK=env
SECRETS_CACHE_TTL_SECONDS=300
SECRETS_AUTO_REFRESH=true
SECRETS_ENCRYPT_CACHE=true
SECRETS_AUDIT_ENABLED=true
SECRETS_AUDIT_PERSIST=true
SECRETS_ROTATION_CRON=0 3 * * *

# GCP Secret Manager
# Set this to your GCP project id (override in .env).
GCP_SECRETS_PROJECT_ID=YOUR_GCP_PROJECT_ID
GCP_SECRETS_PREFIX=your-prefix

# ─── Local dev authentication (RECOMMENDED PATH) ─────────────────────────
# Use Application Default Credentials (ADC). One-time setup:
#
#   gcloud auth application-default login
#
# After login, gcloud writes credentials to ~/.config/gcloud/application_default_credentials.json
# and the Secret Manager client picks them up automatically — no key file needed.
# The boot-time preflight in `gcp-provider.ts` validates ADC eagerly and prints
# this command in the error message if ADC is missing or expired.
#
# ─── Service account file (legacy, only when ADC is unavailable) ─────────
# Prefer ADC. Use a key file only in environments where you cannot run gcloud
# (e.g. air-gapped CI with a pre-issued key). Keep the file out of git.
# GCP_SECRETS_CREDENTIALS_FILE=./service-account-key.json

# ============================================
# Branding Configuration
# ============================================
AILIN_HIDE_MODELS=false
AILIN_BRAND_NAME=Ailin¹
AILIN_MINIMAL_METADATA=false
AILIN_LOG_DETAILED_METADATA=true

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Application Metadata
APP_VERSION=2.1.0
CLI_MIN_VERSION=0.0.1
CLI_LATEST_VERSION=0.1.9
GIT_COMMIT_SHA=
BUILD_TIMESTAMP=

# ============================================
# Database (PostgreSQL) - Non-sensitive Config
# ============================================
# Connection string comes from GCP Secret: <prefix>-database-url
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=50
DATABASE_CONNECTION_TIMEOUT=5000
DATABASE_IDLE_TIMEOUT=30000

# ============================================
# Redis (Cache & Queue) - Non-sensitive Config
# ============================================
# Connection strings come from GCP Secrets:
# - <prefix>-redis-url
# - <prefix>-redis-global-url
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# NOT supported yet — redis-client.ts fails fast rather than silently
# ignoring this (BullMQ's key scheme has no hash-tag prefixing and the
# redis-global cache layer uses db:1, both incompatible with Cluster mode's
# sharding). Use REDIS_SENTINEL_ENABLED below for HA instead.
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_NODES=
# Sentinel-monitored HA (automatic primary failover, no sharding — safe for
# every current Redis consumer, unlike Cluster mode above).
REDIS_SENTINEL_ENABLED=false
REDIS_SENTINEL_NAME=mymaster
# comma-separated host:port list, e.g. sentinel-1:26379,sentinel-2:26379,sentinel-3:26379
REDIS_SENTINELS=

# Scale-to-100k Phase 5 (issue #150) — money-path Redis (BullMQ queues + the
# idempotency store, via getQueueRedisClient()/createRedisClient()). Every
# field below falls back to the general REDIS_* value above when unset, so
# leaving these blank keeps today's single-instance behavior; set them to
# point the money path at a physically separate, non-evicting Redis so
# cache/rate-limit churn on the general instance can never OOM or evict an
# in-flight job or idempotency record.
REDIS_QUEUE_HOST=
REDIS_QUEUE_PORT=
REDIS_QUEUE_DB=
REDIS_QUEUE_SENTINEL_ENABLED=false
REDIS_QUEUE_SENTINEL_NAME=
REDIS_QUEUE_SENTINELS=

# ============================================
# Queue (BullMQ)
# ============================================
QUEUE_ENABLED=true
QUEUE_NAME=chat-requests
QUEUE_WORKER_COUNT=20
QUEUE_WORKER_CONCURRENCY=100
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_INITIAL_DELAY_MS=1000
QUEUE_BACKOFF_STRATEGY=exponential
QUEUE_RESULT_TTL_SECONDS=86400
QUEUE_STATUS_TTL_SECONDS=600
QUEUE_MAX_QUEUE_TIME_SECONDS=120
QUEUE_POLL_INTERVAL_MS=2000
QUEUE_RUN_WORKERS_IN_API=true
QUEUE_WORKER_METRICS_PORT=9465

# ============================================
# JWT Authentication
# ============================================
# JWT secret comes from GCP Secret: <prefix>-jwt-secret
JWT_EXPIRES_IN=24h

# ============================================
# Service-token auth (BFF → ci-internal)
# ============================================
# These settings govern the `/v1/internal/*` endpoints that the dev/ BFF
# (and other trusted services) call on behalf of end users. Tokens are
# RS256, validated against id/'s JWKS via the existing federation config,
# and required to carry this audience plus an X-Acting-User header naming
# the console user. The user is then resolved server-side and used for
# all DB lookups — the BFF never names organizationId, only the user id.
#
# Audience the service-auth middleware will accept on the `aud` claim.
# Must be one of the audiences id/ has whitelisted for the calling client
# (see DEV_SERVER_ALLOWED_AUDIENCES on id/api/.env.example).
SERVICE_TOKEN_AUDIENCE=ailin-ci

# ============================================
# Personal Access Tokens (PATs)
# ============================================
# Policy for end-user API keys created via /v1/internal/api-keys. These
# values are enforced when a key is created — existing keys with longer
# expirations are unaffected.
#
# Maximum lifetime in days. Set to 0 (and ALLOW_NO_EXPIRATION=true) to
# permit indefinite tokens. Default 730 mirrors GitHub's fine-grained
# PAT max — strikes a balance between rotation hygiene and CI ergonomics.
API_KEY_MAX_EXPIRATION_DAYS=730
# Whether to allow tokens with no expiration at all. Default true; set to
# false in regulated environments to force every token to carry a bound.
API_KEY_ALLOW_NO_EXPIRATION=true

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=3600000

# ============================================
# Provider Base URLs (Non-sensitive)
# ============================================
# API keys come from GCP Secrets (<prefix>-*-key)

# Provider: OpenAI
OPENAI_ORGANIZATION=your-org-id-here
OPENAI_PROJECT_ID=your-project-id-here
OPENAI_BASE_URL=https://api.openai.com/v1
# Scale-to-100k Phase 2 (issue #152): optional multi-account pool, rotated
# round-robin alongside OPENAI_API_KEY so this provider's throughput isn't
# capped by a single account's rate limit. JSON array of additional keys.
# OPENAI_API_KEY_POOL=["sk-...","sk-..."]

# Provider: Anthropic
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_ORGANIZATION_ID=your-org-id-here
# ANTHROPIC_API_KEY_POOL=["sk-ant-...","sk-ant-..."]

# Provider: Google (Gemini)
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
# GOOGLE_API_KEY_POOL=["AIza...","AIza..."]

# Provider: DeepSeek
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Provider: Mistral
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Provider: xAI (Grok)
XAI_BASE_URL=https://api.x.ai

# Provider: Cohere
COHERE_BASE_URL=https://api.cohere.ai

# Provider: NVIDIA
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_HUB_BASE_URL=https://integrate.api.nvidia.com/v1

# Provider: AiHubMix
AIHUBMIX_BASE_URL=https://aihubmix.com/v1

# Provider: Novita
NOVITA_BASE_URL=https://api.novita.ai/openai/v1

# Provider: Moonshot
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Provider: MiniMax
MINIMAX_BASE_URL=https://api.minimax.io/v1

# Provider: Jina
JINA_API_BASE_URL=https://api.jina.ai/v1
JINA_DEEPSEARCH_BASE_URL=https://deepsearch.jina.ai/v1
JINA_READER_BASE_URL=https://r.jina.ai
JINA_SEARCH_BASE_URL=https://s.jina.ai

# Provider: Friendli
FRIENDLI_BASE_URL=https://api.friendli.ai/serverless/v1
FRIENDLI_TEAM_ID=your-team-id-here

# Provider: AIML
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODELS_BASE_URL=https://api.aimlapi.com

# Provider: ImageRouter
IMAGEROUTER_BASE_URL=https://api.imagerouter.io

# Provider: Vertex AI (Google Cloud)
VERTEX_AI_PROJECT_ID=YOUR_GCP_PROJECT_ID
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_BASE_URL=
VERTEX_AI_USE_EXPRESS_MODE=false

# Provider: Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Provider: OpenRouter
OPENROUTER_APP_URL=https://ailin.dev
OPENROUTER_APP_NAME=Ailin¹

# Provider: ORQ.ai
ORQAI_BASE_URL=https://api.orq.ai/v2/router
ORQAI_MODELS_BASE_URL=https://api.orq.ai

# Provider: Eden AI
EDENAI_BASE_URL=https://api.edenai.run/v3/llm

# Provider: Helicone AI Gateway
HELICONEAI_BASE_URL=https://ai-gateway.helicone.ai/v1

# Provider: AWS Bedrock
AWS_BEDROCK_REGION=us-east-1

# ============================================
# Observability: OpenTelemetry
# ============================================
OTEL_ENABLED=true
OTEL_SERVICE_NAME=ci-api
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14268/api/traces
OTEL_EXPORTER_PROMETHEUS_PORT=9464

# ============================================
# Monitoring: Prometheus
# ============================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_TOKEN=generate-long-token

# ============================================
# Cache Configuration
# ============================================
CACHE_ENABLED=true
CACHE_TTL_DEFAULT=3600
CACHE_TTL_MODELS=3600
CACHE_TTL_RESPONSES=86400
CACHE_TTL_EMBEDDINGS=604800
CACHE_MAX_SIZE_MB=256
CACHE_MAX_IN_MEMORY_ENTRIES=5000

# ============================================
# Security
# ============================================
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
HELMET_ENABLED=true
COMPRESSION_ENABLED=true
MAX_REQUEST_SIZE_MB=10
SECURITY_RBAC_DEFAULT_ROLE=viewer
SECURITY_RBAC_SUPER_ROLES=owner,admin
SECURITY_AUDIT_ENABLED=true
SECURITY_AUDIT_RETENTION_DAYS=365

# ============================================
# Payments / Stripe
# ============================================
# Stripe keys come from GCP Secrets:
# - <prefix>-stripe-secret-key
# - <prefix>-stripe-webhook-secret
STRIPE_ENABLED=true
STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key-here
STRIPE_API_VERSION=2024-06-20
STRIPE_API_BASE_URL=https://api.stripe.com
STRIPE_DEFAULT_CURRENCY=usd
STRIPE_AUTOMATIC_TAX=true

# ============================================
# Internal M2M service-token auth (/v1/internal/*)
# ============================================
# The dev/platform BFF mints short-lived RS256 service tokens at id
# (client_credentials, client_id=ailin-dev-server, audience=ailin-ci) and
# calls ci's internal API-key endpoints with Bearer + X-Acting-User. ci
# verifies these against id's JWKS (same keypair as user OIDC tokens) — a
# path SEPARATE from user-token federation above. Defaults below match prod.
SERVICE_AUTH_ENABLED=true
SERVICE_AUTH_ISSUER=https://ailin.id
SERVICE_AUTH_AUDIENCE=ailin-ci
SERVICE_AUTH_JWKS_URI=https://ailin.id/.well-known/jwks.json
SERVICE_AUTH_ALLOWED_CLIENTS=ailin-dev-server
# SERVICE_AUTH_JWKS_CACHE_TTL_SECONDS=300
# SERVICE_AUTH_CLOCK_TOLERANCE_SECONDS=30

# ============================================
# Email (SMTP)
# ============================================
# SMTP password comes from GCP Secret: <prefix>-smtp-pass
AUTH_EMAIL_PROVIDER=smtp
AUTH_EMAIL_FROM_EMAIL=no-reply@ailin.dev
AUTH_EMAIL_FROM_NAME=Ailin¹ Developer Tool
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@example.com

# ============================================
# Feature Flags
# ============================================
FEATURE_STREAMING=true
FEATURE_FUNCTION_CALLING=true
FEATURE_VISION=true
FEATURE_EMBEDDINGS=true
FEATURE_CACHING=true
FEATURE_AUTO_LEARNING=true
FEATURE_COMPETITIVE_EXECUTION=true
FEATURE_ARBITRATION=true

# ============================================
# Auto-Learning
# ============================================
AUTO_LEARNING_ENABLED=true
AUTO_LEARNING_BUCKET_SIZE_HOURS=1
AUTO_LEARNING_RETENTION_DAYS=365

# ============================================
# Orchestration
# ============================================
ORCHESTRATION_MAX_MODELS=9
ORCHESTRATION_DEFAULT_STRATEGY=auto
ORCHESTRATION_ENABLE_PARALLEL=true
ORCHESTRATION_ENABLE_COMPETITIVE=true
ORCHESTRATION_ENABLE_ARBITRATION=true

# ============================================
# Collective Coordination Layer (Sensitivity Consensus)
# ============================================
# Master switch — disabled by default, enable to activate sensitivity-consensus strategy
CI_SENSITIVITY_CONSENSUS_ENABLED=false
CI_COORDINATION_MAX_ROUNDS=3
CI_COORDINATION_MIN_CONVERGENCE_SCORE=0.82
CI_COORDINATION_MAX_DECISION_FLIP_RATE=0.15
CI_COORDINATION_MAX_DISSENT=0.35
CI_COORDINATION_MAX_COST_USD=0.50
CI_COORDINATION_MAX_LATENCY_MS=60000
CI_COORDINATION_STOP_ON_CRITICAL_RISK=true
CI_COORDINATION_MIN_MODELS=3
CI_COORDINATION_MAX_MODELS=5
CI_COORDINATION_REQUIRE_QUALITY=0.8
CI_COORDINATION_AGGREGATION_METHOD=weighted_confidence
CI_COORDINATION_PERSIST_AUDIT=false
CI_COORDINATION_ENABLE_EXPERIMENTS=true

# ============================================
# Ailin Virtual Model Aliases
# ============================================
# Optional comma-separated aliases that always resolve to autonomous orchestration.
# Example: AILIN_AUTO_MODEL_ALIASES=ailin-smart,ailin-pro
AILIN_AUTO_MODEL_ALIASES=

# Optional JSON array with custom alias profiles.
# Example:
# AILIN_VIRTUAL_MODEL_PROFILES=[{"id":"ailin-research","strategy":"consensus","qualityTarget":0.95,"maxCost":0.08,"endpoints":["chat","responses"]}]
AILIN_VIRTUAL_MODEL_PROFILES=

# ============================================
# Cost Optimization
# ============================================
COST_OPTIMIZATION_ENABLED=true
COST_OPTIMIZATION_TARGET_SAVINGS=0.63
COST_OPTIMIZATION_MAX_BUDGET_PER_REQUEST=1.00

# ============================================
# Development
# ============================================
MOCK_PROVIDERS=false
ENABLE_SWAGGER=true
ENABLE_PLAYGROUND=true
ENABLE_GRACEFUL_SHUTDOWN=true
SHUTDOWN_TIMEOUT_MS=30000


# ============================================================================
# GATEWAY MIDDLEWARE CONFIGURATION
# ============================================================================
QUOTA_SERVICE_URL=http://gateway-quota:5004
SIGNATURE_VERIFIER_URL=http://gateway-signature-verifier:5005
QUOTA_SERVICE_TIMEOUT=5
SIGNATURE_VERIFIER_TIMEOUT=5
SENSITIVE_ROUTES=/payment,/billing,/admin,/console/api/admin
