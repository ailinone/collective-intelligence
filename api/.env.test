# ============================================
# Ailin Dev API - Test Environment
# ============================================
# All secrets are in GCP Secret Manager
# Project: YOUR_GCP_PROJECT_ID | Prefix: <your-prefix>-*
# ============================================

# ============================================
# Secrets Manager Configuration
# ============================================
SECRETS_PROVIDER_PRIMARY=gcp
GCP_SECRETS_PROJECT_ID=YOUR_GCP_PROJECT_ID
GCP_SECRETS_PREFIX=your-prefix

# ============================================
# Test Configuration
# ============================================
NODE_ENV=test
TEST_USE_LOCAL_SERVICES=true

# Database - Test DB (local or CI)
# Connection string comes from GCP Secret: <prefix>-database-url (test version)
# Or use local: postgresql://ailin_dev:ailin_dev_password@127.0.0.1:5432/ailin_dev_test
DATABASE_URL=postgresql://ailin_dev:ailin_dev_password@127.0.0.1:5432/ailin_dev_test?schema=public

# Redis - Test instance
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT - Test secret
# In CI/CD, this comes from GCP Secret: <prefix>-jwt-secret
JWT_SECRET=change-me-test-jwt-secret-at-least-32-characters-long

# ============================================
# Provider Base URLs
# ============================================
# In CI/CD, real API keys can be loaded from your secret manager
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_BASE_URL=https://api.anthropic.com
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MISTRAL_BASE_URL=https://api.mistral.ai/v1
XAI_BASE_URL=https://api.x.ai/v1
COHERE_BASE_URL=https://api.cohere.ai

# ============================================
# Provider API Keys (Test Mocks - não fazem chamadas reais)
# ============================================
# Em testes unitários, os adapters são mockados
# Em testes de integração, use TEST_MOCK_PROVIDERS=true
OPENAI_API_KEY=sk-test-ailin-mock-openai-key-do-not-use-in-production
ANTHROPIC_API_KEY=sk-ant-test-ailin-mock-anthropic-key
GOOGLE_API_KEY=AIza-test-ailin-mock-google-key
DEEPSEEK_API_KEY=sk-test-ailin-mock-deepseek-key
MISTRAL_API_KEY=test-ailin-mock-mistral-key
XAI_API_KEY=xai-test-ailin-mock-key
COHERE_API_KEY=test-ailin-mock-cohere-key

# Mock providers in integration tests (não faz chamadas HTTP reais)
TEST_MOCK_PROVIDERS=true

# ============================================
# Stripe (Test Mode)
# ============================================
# Keys come from GCP Secrets: <prefix>-stripe-secret-key
STRIPE_ENABLED=true
STRIPE_SUCCESS_URL=https://example.com/billing/success
STRIPE_CANCEL_URL=https://example.com/billing/cancel
